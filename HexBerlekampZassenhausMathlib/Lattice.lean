/--
Tight package for the BHKS cut-radius bound on a true-factor CLD vector.

Where `TrueFactorCLDNormBound` only certifies `ÔÇľvÔÇľ┬▓ ÔëĄ bhksCutRadiusSq4`, this
certificate is four times stronger: `4┬ĚÔÇľvÔÇľ┬▓ ÔëĄ bhksCutRadiusSq4`, equivalently
`ÔÇľvÔÇľ┬▓ ÔëĄ bhksCutRadiusSq4 / 4 = factorCount + coeffWidth┬ĚfactorCount┬▓/4`.

This is the design-radius bound the prefix cut consumes.  The prefix cut retains
rows at the design radius `r`, where `bhksCutRadiusSq4 = 4┬Ěr┬▓` (the field stores
*four times* the squared radius).  The survivor-span lemma therefore needs the
tight hypothesis `4┬ĚÔÇľvÔÇľ┬▓ ÔëĄ bhksCutRadiusSq4`, not the loose
`ÔÇľvÔÇľ┬▓ ÔëĄ bhksCutRadiusSq4` ÔÇö the latter is `4├Ś` too weak for the prefix cut.
-/
structure TrueFactorCLDTightNormBound
    (L : Hex.BhksLatticeBasis) (S : LiftedFactorSupport L) where
  four_mul_sq_norm_le :
    4 * (ÔłĹ i : Fin (L.factorCount + L.coeffWidth),
      ((((trueFactorCLDVector L S)[i] : ÔäĄ) : ÔäŁ) ^ 2)) ÔëĄ
        (Hex.bhksCutRadiusSq4 L : ÔäŁ)

namespace TrueFactorCLDTightNormBound

/-- The tight certificate implies the loose one: `4┬ĚÔÇľvÔÇľ┬▓ ÔëĄ R` with `ÔÇľvÔÇľ┬▓ Ôëą 0`
forces `ÔÇľvÔÇľ┬▓ ÔëĄ R`. -/
theorem toNormBound
    {L : Hex.BhksLatticeBasis} {S : LiftedFactorSupport L}
    (D : TrueFactorCLDTightNormBound L S) :
    TrueFactorCLDNormBound L S := by
  refine ÔčĘ?_Ôčę
  have hnonneg : (0 : ÔäŁ) ÔëĄ
      ÔłĹ i : Fin (L.factorCount + L.coeffWidth),
        ((((trueFactorCLDVector L S)[i] : ÔäĄ) : ÔäŁ) ^ 2) :=
    Finset.sum_nonneg (fun i _ => sq_nonneg _)
  linarith [D.four_mul_sq_norm_le]

end TrueFactorCLDTightNormBound

/--
Tight CLD-tail squared-sum bound from the genuinely tighter per-column high-bit
estimate `2┬Ě|╬ú i Ôłł S, cldRows[i][j]| ÔëĄ factorCount` (i.e. `|col j| ÔëĄ factorCount/2`).

This halves the loose per-column bound `|col j| ÔëĄ factorCount` used by
`cldTailSq_le_of_colBound`.  Since `4┬Ěz┬▓ = (2┬Ěz)┬▓` and `(2┬Ěz).natAbs = 2┬Ěz.natAbs`,
each column contributes `4┬Ěcol┬▓ ÔëĄ factorCount┬▓`, so the tail satisfies
`4┬Ětail ÔëĄ coeffWidth┬ĚfactorCount┬▓`.
-/
theorem cldTailSq4_le_of_tightColBound
    {L : Hex.BhksLatticeBasis} (S : LiftedFactorSupport L)
    (hcol :
      ÔłÇ j : Fin L.coeffWidth,
        2 * ((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ).natAbs ÔëĄ
          L.factorCount) :
    4 * (ÔłĹ j : Fin L.coeffWidth,
        (((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ) : ÔäŁ) ^ 2)
      ÔëĄ (L.coeffWidth * L.factorCount * L.factorCount : ÔäŁ) := by
  rw [Finset.mul_sum]
  calc
    (ÔłĹ j : Fin L.coeffWidth,
        4 * (((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ) : ÔäŁ) ^ 2)
        ÔëĄ ÔłĹ _j : Fin L.coeffWidth, ((L.factorCount : ÔäŁ) ^ 2) := by
          refine Finset.sum_le_sum (fun j _ => ?_)
          set z : ÔäĄ := (trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] with hz
          have hnat : (2 * z).natAbs ÔëĄ L.factorCount := by
            rw [Int.natAbs_mul]; simpa using hcol j
          have hsq := intSq_le_of_natAbs_le (2 * z) L.factorCount hnat
          have hexpand : (((2 * z : ÔäĄ)) : ÔäŁ) ^ 2 = 4 * ((z : ÔäĄ) : ÔäŁ) ^ 2 := by
            push_cast; ring
          rw [hexpand] at hsq
          exact hsq
    _ = (L.coeffWidth * L.factorCount * L.factorCount : ÔäŁ) := by
          simp [pow_two, mul_assoc]

/--
Reduction of the tight BHKS cut-radius norm bound to a tight bound on the CLD
tail alone (`4┬Ětail ÔëĄ coeffWidth┬ĚfactorCount┬▓`).

The projected first block is the `0/1` support indicator, whose squared norm is
at most `factorCount` (structural, via `project_eq`), so `4┬Ěfirst ÔëĄ 4┬ĚfactorCount`.
Adding the tight tail gives `4┬ĚÔÇľvÔÇľ┬▓ ÔëĄ 4┬ĚfactorCount + coeffWidth┬ĚfactorCount┬▓ =
bhksCutRadiusSq4`.
-/
theorem trueFactorCLDTightNormBound_of_cldTail_four_mul_sq_sum_le
    {L : Hex.BhksLatticeBasis} (S : LiftedFactorSupport L)
    (hL : BhksBlockForm L)
    (htail : 4 * (ÔłĹ j : Fin L.coeffWidth,
        (((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ) : ÔäŁ) ^ 2)
      ÔëĄ (L.coeffWidth * L.factorCount * L.factorCount : ÔäŁ)) :
    TrueFactorCLDTightNormBound L S := by
  refine ÔčĘ?_Ôčę
  rw [Fin.sum_univ_add, mul_add]
  have hfirst_eq : ÔłÇ i : Fin L.factorCount,
      ((trueFactorCLDVector L S)[Fin.castAdd L.coeffWidth i] : ÔäĄ) = indicatorVector S i :=
    fun i => trueFactorCLDVector_project_of_blockForm S hL i
  have hfirst : (ÔłĹ i : Fin L.factorCount,
      (((trueFactorCLDVector L S)[Fin.castAdd L.coeffWidth i] : ÔäĄ) : ÔäŁ) ^ 2)
      ÔëĄ (L.factorCount : ÔäŁ) := by
    have heq : (ÔłĹ i : Fin L.factorCount,
        (((trueFactorCLDVector L S)[Fin.castAdd L.coeffWidth i] : ÔäĄ) : ÔäŁ) ^ 2)
        = ÔłĹ i : Fin L.factorCount, (((indicatorVector S i : ÔäĄ) : ÔäŁ) ^ 2) :=
      Finset.sum_congr rfl (fun i _ => by rw [hfirst_eq i])
    rw [heq]
    exact indicatorVector_sq_sum_le_factorCount S
  have hfirst4 : 4 * (ÔłĹ i : Fin L.factorCount,
      (((trueFactorCLDVector L S)[Fin.castAdd L.coeffWidth i] : ÔäĄ) : ÔäŁ) ^ 2)
      ÔëĄ 4 * (L.factorCount : ÔäŁ) := by linarith
  refine (add_le_add hfirst4 htail).trans (le_of_eq ?_)
  unfold Hex.bhksCutRadiusSq4
  push_cast
  ring

/--
Tight per-column CLD estimate for a support that has been tied to concrete
