/--
Reduction of the BHKS cut-radius norm bound (#7593 deliverable 4) to a bound on
the CLD tail alone.

The projected first block is the `0/1` support indicator, whose squared norm is
at most `factorCount` (structural, via `project_eq`).  The cut radius
`bhksCutRadiusSq4 = 4┬ĚfactorCount + coeffWidth┬ĚfactorCount┬▓` leaves
`3┬ĚfactorCount` of slack over that block, so the full bound follows from the CLD
tail squared-sum being at most `coeffWidth┬ĚfactorCount┬▓`.

That tail bound is the genuinely missing lower-level estimate: the executable
CLD entries `cldRows` are bounded only by the hypothesis-gated
`Hex.bhksCoeffBound`, which `bhksCutRadiusSq4` does not reference.  This lemma
makes that dependency explicit (it is the single residual obligation a CLD
high-bit magnitude analysis must discharge), rather than leaving it unproven.
-/
theorem trueFactorCLDNormBound_of_cldTail_sq_sum_le
    {L : Hex.BhksLatticeBasis} (S : LiftedFactorSupport L)
    (hL : BhksBlockForm L)
    (htail : (ÔłĹ j : Fin L.coeffWidth,
        (((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ) : ÔäŁ) ^ 2)
      ÔëĄ (L.coeffWidth * L.factorCount * L.factorCount : ÔäŁ)) :
    TrueFactorCLDNormBound L S := by
  refine ÔčĘ?_Ôčę
  rw [Fin.sum_univ_add]
  have hfirst_eq : ÔłÇ i : Fin L.factorCount,
      ((trueFactorCLDVector L S)[Fin.castAdd L.coeffWidth i] : ÔäĄ) = indicatorVector S i :=
    fun i => trueFactorCLDVector_project_of_blockForm S hL i
  have hfirst : (ÔłĹ i : Fin L.factorCount,
      (((trueFactorCLDVector L S)[Fin.castAdd L.coeffWidth i] : ÔäĄ) : ÔäŁ) ^ 2)
      ÔëĄ (L.factorCount : ÔäŁ) := by
    have heq : (ÔłĹ i : Fin L.factorCount,
        (((trueFactorCLDVector L S)[Fin.castAdd L.coeffWidth i] : ÔäĄ) : ÔäŁ) ^ 2)
        = ÔłĹ i : Fin L.factorCount, (((indicatorVector S i : ÔäĄ) : ÔäŁ) ^ 2) :=
      Finset.sum_congr rfl (fun i _ => by rw [hfirst_eq i])
    rw [heq]
    exact indicatorVector_sq_sum_le_factorCount S
  refine (add_le_add hfirst htail).trans ?_
  unfold Hex.bhksCutRadiusSq4
  push_cast
  nlinarith [Nat.cast_nonneg (╬▒ := ÔäŁ) L.factorCount]

private theorem intSq_le_of_natAbs_le (z : ÔäĄ) (B : Nat)
    (h : z.natAbs ÔëĄ B) :
    ((z : ÔäŁ) ^ 2) ÔëĄ (B : ÔäŁ) ^ 2 := by
  have hR : (z.natAbs : ÔäŁ) ÔëĄ (B : ÔäŁ) := by exact_mod_cast h
  have hsq : ((z.natAbs : ÔäŁ) ^ 2) ÔëĄ (B : ÔäŁ) ^ 2 := by
    have hdiff : 0 ÔëĄ (B : ÔäŁ) - (z.natAbs : ÔäŁ) := sub_nonneg.mpr hR
    have hsum : 0 ÔëĄ (B : ÔäŁ) + (z.natAbs : ÔäŁ) := by positivity
    have hmul : 0 ÔëĄ ((B : ÔäŁ) - (z.natAbs : ÔäŁ)) *
        ((B : ÔäŁ) + (z.natAbs : ÔäŁ)) :=
      mul_nonneg hdiff hsum
    nlinarith
  rcases Int.natAbs_eq z with hz | hz
  ┬Ě rw [hz]
    exact hsq
  ┬Ě rw [hz]
    simpa using hsq

/--
CLD-tail squared-sum bound from a per-column bound on the true-factor CLD
column sums.  This is the algebraic target left after the executable CLD
analysis proves each support sum is bounded by `factorCount`.
-/
theorem cldTailSq_le_of_colBound
    {L : Hex.BhksLatticeBasis} (S : LiftedFactorSupport L)
    (hcol :
      ÔłÇ j : Fin L.coeffWidth,
        ((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ).natAbs ÔëĄ
          L.factorCount) :
    (ÔłĹ j : Fin L.coeffWidth,
        (((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ) : ÔäŁ) ^ 2)
      ÔëĄ (L.coeffWidth * L.factorCount * L.factorCount : ÔäŁ) := by
  calc
    (ÔłĹ j : Fin L.coeffWidth,
        (((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ) : ÔäŁ) ^ 2)
        ÔëĄ ÔłĹ _j : Fin L.coeffWidth, ((L.factorCount : ÔäŁ) ^ 2) := by
          exact Finset.sum_le_sum (fun j _ =>
            intSq_le_of_natAbs_le
              ((trueFactorCLDVector L S)[Fin.natAdd L.factorCount j] : ÔäĄ)
              L.factorCount (hcol j))
    _ = (L.coeffWidth * L.factorCount * L.factorCount : ÔäŁ) := by
          simp [pow_two, mul_assoc]

/--
Produce the existing BHKS true-factor CLD norm certificate from a per-column
bound on the true-factor CLD column sums.
-/
theorem normBound_of_colBound
