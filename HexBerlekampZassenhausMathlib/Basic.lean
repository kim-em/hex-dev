  apply hpartition.support_subset_of_dvd_recombinationCandidate
    hirr hfactor_dvd_target hTJ
  · exact hcore_monic
  · rw [← recombinationCandidate_eq_liftedFactorProductCandidate]
    exact hfactor_dvd_candidate
  · exact hSJ
  · exact hrep

