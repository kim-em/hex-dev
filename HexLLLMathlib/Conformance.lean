import HexLLLMathlib.Basic

/-!
Core conformance checks for `hex-lll-mathlib`.

Oracle: none
Mode: always
Covered operations:
- `latticeSubmodule`
- `mem_latticeSubmodule_iff` and `memLattice_iff_mem_latticeSubmodule`
- `row_mem_latticeSubmodule`
- `intRowToEuclidean` and `intVectorToEuclidean`
- `reduced_first_row_norm_sq_le_of_mem_latticeSubmodule` theorem surface
Covered properties:
- concrete executable lattice witnesses transport to Mathlib submodule
  membership and back through the bridge equivalences
- every committed matrix row belongs to its generated Mathlib submodule
- executable integer rows and Mathlib-side integer vectors expose the expected
  Euclidean coordinates on committed inputs
- the short-vector bridge theorem typechecks against the advertised Mathlib
  lattice-membership hypothesis shape
Covered edge cases:
- zero-row matrices and the zero lattice vector
- a single nonzero generator row
- dependent rows with a target generated by multiple row coefficients
- signed coordinates in executable and Mathlib-side vectors
-/

namespace HexLLLMathlib

private abbrev fin0 : Fin 1 := ⟨0, by decide⟩
private abbrev fin2_0 : Fin 2 := ⟨0, by decide⟩
private abbrev fin2_1 : Fin 2 := ⟨1, by decide⟩

private def zeroBasis : Hex.Matrix Int 1 2 := 0

private def singleBasis : Hex.Matrix Int 1 2 :=
  Hex.Matrix.ofFn fun _ j =>
    match j.val with
    | 0 => 3
    | _ => -4

private def dependentBasis : Hex.Matrix Int 2 2 :=
  Hex.Matrix.ofFn fun i j =>
    match i.val, j.val with
    | 0, 0 => 1
    | 0, _ => 2
    | _, 0 => 2
    | _, _ => 4

private def zeroVec : Vector Int 2 := 0

private def singleRowVec : Vector Int 2 :=
  Vector.ofFn fun j =>
    match j.val with
    | 0 => 3
    | _ => -4

private def dependentTarget : Vector Int 2 :=
  Vector.ofFn fun j =>
    match j.val with
    | 0 => 5
    | _ => 10

private def dependentCoeffs : Vector Int 2 :=
  Vector.ofFn fun i =>
    match i.val with
    | 0 => 1
    | _ => 2

private def signedMathVector : Fin 2 → ℤ
  | ⟨0, _⟩ => -7
  | ⟨1, _⟩ => 9

#guard Hex.Matrix.row zeroBasis fin0 = zeroVec
#guard Hex.Matrix.row singleBasis fin0 = singleRowVec
#guard Hex.Matrix.rowCombination dependentBasis dependentCoeffs = dependentTarget

example : Hex.Matrix.memLattice zeroBasis zeroVec := by
  exact ⟨Vector.ofFn fun _ : Fin 1 => (0 : Int), by rfl⟩

example : Hex.Matrix.memLattice singleBasis singleRowVec := by
  exact ⟨Vector.ofFn fun _ : Fin 1 => (1 : Int), by rfl⟩

example : Hex.Matrix.memLattice dependentBasis dependentTarget := by
  exact ⟨dependentCoeffs, by rfl⟩

example :
    HexMatrixMathlib.vectorEquiv zeroVec ∈ latticeSubmodule zeroBasis := by
  exact (mem_latticeSubmodule_iff zeroBasis zeroVec).mpr (by
    exact ⟨Vector.ofFn fun _ : Fin 1 => (0 : Int), by rfl⟩)

example :
    HexMatrixMathlib.vectorEquiv singleRowVec ∈ latticeSubmodule singleBasis := by
  simpa using row_mem_latticeSubmodule singleBasis fin0

example :
    HexMatrixMathlib.vectorEquiv dependentTarget ∈ latticeSubmodule dependentBasis := by
  exact (memLattice_iff_mem_latticeSubmodule dependentBasis dependentTarget).mp
    ⟨dependentCoeffs, by rfl⟩

example :
    HexMatrixMathlib.vectorEquiv zeroVec ∈ latticeSubmodule zeroBasis ↔
      Hex.Matrix.memLattice zeroBasis zeroVec :=
  mem_latticeSubmodule_iff zeroBasis zeroVec

example :
    Hex.Matrix.memLattice singleBasis singleRowVec ↔
      HexMatrixMathlib.vectorEquiv singleRowVec ∈ latticeSubmodule singleBasis :=
  memLattice_iff_mem_latticeSubmodule singleBasis singleRowVec

example : (intRowToEuclidean singleRowVec : Fin 2 → ℝ) fin2_0 = 3 := by
  norm_num [intRowToEuclidean, singleRowVec, fin2_0]

example : (intRowToEuclidean singleRowVec : Fin 2 → ℝ) fin2_1 = -4 := by
  norm_num [intRowToEuclidean, singleRowVec, fin2_1]

example : (intRowToEuclidean zeroVec : Fin 2 → ℝ) fin2_0 = 0 := by
  norm_num [intRowToEuclidean, zeroVec, fin2_0]

example : (intVectorToEuclidean signedMathVector : Fin 2 → ℝ) fin2_0 = -7 := by
  norm_num [intVectorToEuclidean, signedMathVector, fin2_0]

example : (intVectorToEuclidean signedMathVector : Fin 2 → ℝ) fin2_1 = 9 := by
  norm_num [intVectorToEuclidean, signedMathVector, fin2_1]

example : (intVectorToEuclidean (0 : Fin 2 → ℤ) : Fin 2 → ℝ) fin2_1 = 0 := by
  norm_num [intVectorToEuclidean, fin2_1]

example
    (b : Hex.Matrix Int n m) (δ : Rat)
    (hδ : (1 : Rat) / 4 < δ) (hδ' : δ ≤ 1) (hn : 1 ≤ n)
    (hli : Hex.Matrix.independent b) (hred : Hex.isLLLReduced b δ)
    (x : Fin m → ℤ) (hx : x ∈ latticeSubmodule b) (hx0 : x ≠ 0) :
    ‖intRowToEuclidean (Hex.Matrix.row b ⟨0, Nat.lt_of_lt_of_le Nat.zero_lt_one hn⟩)‖ ^ 2 ≤
      (((1 / (δ - 1 / 4)) ^ (n - 1) : Rat) : ℝ) *
        ‖intVectorToEuclidean x‖ ^ 2 :=
  reduced_first_row_norm_sq_le_of_mem_latticeSubmodule b δ hδ hδ' hn hli hred x hx hx0

end HexLLLMathlib
